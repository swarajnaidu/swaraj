{
    "welcomeFile": "/index.html",
    "authenticationMethod": "route",
    "routes": [
        {
            "source": "^/odata/v4/(.*)$",
            "destination": "srv-api",
            "authenticationType": "xsuaa",
            "csrfProtection": true
        },
        {
            "source": "^/(.*)$",
            "target": "/$1",
            "localDir": "project1/webapp",
            "authenticationType": "xsuaa"
        }
    ]
}